rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Swipes ───────────────────────────────────────────────────────────────
    match /swipes/{swipeId} {
      // "from" side: queried on load  |  "to" side: getDoc'd to detect a match
      allow read:   if request.auth != null
                    && (resource.data.from == request.auth.uid
                        || resource.data.to  == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.from == request.auth.uid;
    }

    // ── Matches ───────────────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read:   if request.auth != null
                    && request.auth.uid in resource.data.users;
      // doSwipe creates the match document
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.users;
      // MessagesPage updates lastMessage / updatedAt
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.users;
    }

    // ── Messages (sub-collection of a match) ─────────────────────────────────
    match /messages/{matchId}/messages/{messageId} {
      allow read:   if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/matches/$(matchId)).data.users;
      allow create: if request.auth != null
                    && request.resource.data.senderId == request.auth.uid
                    && request.auth.uid in
                       get(/databases/$(database)/documents/matches/$(matchId)).data.users;
    }

    // ── Opportunities ─────────────────────────────────────────────────────────
    match /opportunities/{oppId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.professionalId == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.professionalId == request.auth.uid;
    }

    // ── Applications ──────────────────────────────────────────────────────────
    match /applications/{appId} {
      allow create: if request.auth != null
                    && request.resource.data.studentId == request.auth.uid;
      allow read:   if request.auth != null
                    && (resource.data.studentId == request.auth.uid
                        || get(/databases/$(database)/documents/opportunities/$(resource.data.opportunityId)).data.professionalId == request.auth.uid);
      // Only the opportunity owner may change the status field
      allow update: if request.auth != null
                    && get(/databases/$(database)/documents/opportunities/$(resource.data.opportunityId)).data.professionalId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }
  }
}
